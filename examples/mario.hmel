@name mario
@description super mario bros track
@tempo 200
@octave 3  # default octave
# default duration eighth
@accent-velocity +0.2   # can be with or without +, and - is reverseaccent
@melody
@f  # or @forte - intensity = 8.0
// dash is a rest of the duration
EE-E-CE- !G---<G---
# you can add spaces and new lines to split bars or subsections how ever you want.
# there is no time signature.

@drums
# k=kick t=tom s=snare h=closed-hihat x=clap o=open-hihat c=crash r=ride
k-s-k-s- !k-s-k-!s-
